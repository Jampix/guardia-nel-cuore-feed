{
  "name": "guardia-nel-cuore-infra",
  "version": "1.0.0",
  "description": "Infrastruttura CDK (serverless) per l'app Guardia nel Cuore",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy": "ENVIRONMENT=prod cdk deploy",
    "deploy:prod": "ENVIRONMENT=prod cdk deploy",
    "diff": "ENVIRONMENT=prod cdk diff",
    "infra-dlc:diff": "ts-node --prefer-ts-exts bin/infra-dlc-diff.ts",
    "infra-dlc:guard": "ts-node --prefer-ts-exts bin/infra-dlc-guard.ts",
    "synth": "ENVIRONMENT=prod cdk synth",
    "destroy": "ENVIRONMENT=prod cdk destroy",
    "validate": "ENVIRONMENT=prod npx ts-node --prefer-ts-exts bin/validate.ts",
    "validate:prod": "ENVIRONMENT=prod npx ts-node --prefer-ts-exts bin/validate.ts",
    "docs": "typedoc",
    "docs:build": "typedoc && echo '📚 Documentazione generata in docs/api/'",
    "diagram": "cdk-dia --target docs/diagrams --cdk-out cdk.out",
    "diagram:all": "npm run synth && cdk-dia --target docs/diagrams --cdk-out cdk.out && echo '📊 Diagrammi generati in docs/diagrams/'"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "22.7.9",
    "@types/uuid": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "aws-cdk": "2.176.0",
    "esbuild": "^0.24.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3",
    "source-map-support": "^0.5.21",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.3.0",
    "cdk-dia": "^0.3.0"
  },
  "dependencies": {
    "aws-cdk-lib": "2.176.0",
    "constructs": "^10.0.0",
    "uuid": "^9.0.0"
  },
  "keywords": [
    "aws",
    "cdk",
    "infrastructure",
    "template",
    "devops",
    "iac"
  ],
  "author": "IaC Team",
  "license": "MIT"
}
